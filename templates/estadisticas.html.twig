{% extends 'base.html.twig' %}

{% block title %}Métricas{% endblock %}

{% block page_title %}Métricas & Reportes{% endblock %}
{% block page_subtitle %}Análisis de desempeño del equipo de ventas{% endblock %}

{% block stylesheets %}
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
{% endblock %}

{% block body %}

{# ── Selector de período ───────────────────────────────── #}
<div class="flex flex-wrap items-center justify-between gap-3 mb-6">
    <div class="flex gap-1 bg-white rounded-lg border border-gray-200 p-1">
        {% for period in ['7 días', '30 días', '3 meses', '6 meses', 'Este año'] %}
        <button class="period-btn px-3 py-1.5 rounded-md text-sm font-medium transition-colors {{ loop.index == 2 ? 'bg-blue-600 text-white' : 'text-gray-600 hover:bg-gray-100' }}"
                data-period="{{ loop.index }}">{{ period }}</button>
        {% endfor %}
    </div>
    <div class="flex gap-2">
        <select class="px-3 py-2 border border-gray-200 rounded-lg text-sm bg-white focus:outline-none">
            <option>Todos los asesores</option>
            <option>Ana García</option><option>Juan Pérez</option><option>Luis Torres</option>
        </select>
        <button class="flex items-center gap-2 px-4 py-2 bg-white border border-gray-200 rounded-lg text-sm hover:bg-gray-50 transition-colors">
            <i class="fas fa-download text-gray-500"></i>Exportar PDF
        </button>
    </div>
</div>

{# ── KPIs principales ─────────────────────────────────── #}
<div class="grid grid-cols-2 xl:grid-cols-4 gap-4 mb-6">

    <div class="bg-white rounded-xl border border-gray-100 shadow-sm p-5">
        <div class="flex items-start justify-between mb-3">
            <div class="w-10 h-10 bg-blue-100 rounded-lg flex items-center justify-center">
                <i class="fas fa-chart-line text-blue-600"></i>
            </div>
            <span class="text-xs font-semibold text-green-600 bg-green-50 px-2 py-0.5 rounded-full"><i class="fas fa-arrow-up mr-0.5"></i>18%</span>
        </div>
        <p class="text-2xl font-bold text-gray-900">$4,850,000</p>
        <p class="text-xs text-gray-500 mt-1">Ingresos totales</p>
        <div class="w-full bg-gray-100 rounded-full h-1 mt-3">
            <div class="bg-blue-500 h-1 rounded-full" style="width: 78%"></div>
        </div>
        <p class="text-xs text-gray-400 mt-1">78% del objetivo mensual</p>
    </div>

    <div class="bg-white rounded-xl border border-gray-100 shadow-sm p-5">
        <div class="flex items-start justify-between mb-3">
            <div class="w-10 h-10 bg-green-100 rounded-lg flex items-center justify-center">
                <i class="fas fa-handshake text-green-600"></i>
            </div>
            <span class="text-xs font-semibold text-green-600 bg-green-50 px-2 py-0.5 rounded-full"><i class="fas fa-arrow-up mr-0.5"></i>12%</span>
        </div>
        <p class="text-2xl font-bold text-gray-900">142</p>
        <p class="text-xs text-gray-500 mt-1">Ventas cerradas</p>
        <div class="w-full bg-gray-100 rounded-full h-1 mt-3">
            <div class="bg-green-500 h-1 rounded-full" style="width: 92%"></div>
        </div>
        <p class="text-xs text-gray-400 mt-1">92% del objetivo</p>
    </div>

    <div class="bg-white rounded-xl border border-gray-100 shadow-sm p-5">
        <div class="flex items-start justify-between mb-3">
            <div class="w-10 h-10 bg-amber-100 rounded-lg flex items-center justify-center">
                <i class="fas fa-funnel-dollar text-amber-600"></i>
            </div>
            <span class="text-xs font-semibold text-red-500 bg-red-50 px-2 py-0.5 rounded-full"><i class="fas fa-arrow-down mr-0.5"></i>3%</span>
        </div>
        <p class="text-2xl font-bold text-gray-900">34.2%</p>
        <p class="text-xs text-gray-500 mt-1">Tasa de conversión</p>
        <div class="w-full bg-gray-100 rounded-full h-1 mt-3">
            <div class="bg-amber-500 h-1 rounded-full" style="width: 34%"></div>
        </div>
        <p class="text-xs text-gray-400 mt-1">Meta: 40%</p>
    </div>

    <div class="bg-white rounded-xl border border-gray-100 shadow-sm p-5">
        <div class="flex items-start justify-between mb-3">
            <div class="w-10 h-10 bg-purple-100 rounded-lg flex items-center justify-center">
                <i class="fas fa-clock text-purple-600"></i>
            </div>
            <span class="text-xs font-semibold text-green-600 bg-green-50 px-2 py-0.5 rounded-full"><i class="fas fa-arrow-down mr-0.5"></i>2d</span>
        </div>
        <p class="text-2xl font-bold text-gray-900">18 días</p>
        <p class="text-xs text-gray-500 mt-1">Tiempo promedio de cierre</p>
        <div class="w-full bg-gray-100 rounded-full h-1 mt-3">
            <div class="bg-purple-500 h-1 rounded-full" style="width: 60%"></div>
        </div>
        <p class="text-xs text-gray-400 mt-1">Meta: 15 días</p>
    </div>

</div>

{# ── Gráficas ──────────────────────────────────────────── #}
<div class="grid grid-cols-1 xl:grid-cols-3 gap-5 mb-5">

    <!-- Ventas por mes -->
    <div class="xl:col-span-2 bg-white rounded-xl border border-gray-100 shadow-sm p-5">
        <div class="flex items-center justify-between mb-5">
            <h3 class="font-semibold text-gray-800">Ventas & Ingresos por Mes</h3>
            <div class="flex gap-3 text-xs text-gray-500">
                <span class="flex items-center gap-1.5"><span class="w-3 h-3 rounded-full bg-blue-500 inline-block"></span>Unidades</span>
                <span class="flex items-center gap-1.5"><span class="w-3 h-3 rounded-full bg-green-400 inline-block"></span>Ingresos (x1000)</span>
            </div>
        </div>
        <canvas id="chartVentas" height="120"></canvas>
    </div>

    <!-- Distribución por marca -->
    <div class="bg-white rounded-xl border border-gray-100 shadow-sm p-5">
        <h3 class="font-semibold text-gray-800 mb-5">Ventas por Marca</h3>
        <canvas id="chartMarcas" height="180"></canvas>
        <div id="marcasLegend" class="mt-4 space-y-1.5"></div>
    </div>

</div>

<div class="grid grid-cols-1 xl:grid-cols-2 gap-5 mb-5">

    <!-- Embudo de conversión -->
    <div class="bg-white rounded-xl border border-gray-100 shadow-sm p-5">
        <h3 class="font-semibold text-gray-800 mb-5">Embudo de Conversión</h3>
        <div class="space-y-3" id="embudo-conv"></div>
    </div>

    <!-- Ranking asesores -->
    <div class="bg-white rounded-xl border border-gray-100 shadow-sm p-5">
        <h3 class="font-semibold text-gray-800 mb-5">Ranking de Asesores</h3>
        <div class="space-y-4" id="rankingAsesores"></div>
    </div>

</div>

{# ── Tabla resumen mensual ─────────────────────────────── #}
<div class="bg-white rounded-xl border border-gray-100 shadow-sm overflow-hidden">
    <div class="px-5 py-4 border-b border-gray-100">
        <h3 class="font-semibold text-gray-800">Resumen Mensual</h3>
    </div>
    <div class="overflow-x-auto">
        <table class="min-w-full divide-y divide-gray-100">
            <thead class="bg-gray-50">
                <tr>
                    <th class="px-5 py-3 text-left text-xs font-semibold text-gray-500 uppercase">Mes</th>
                    <th class="px-5 py-3 text-left text-xs font-semibold text-gray-500 uppercase">Leads</th>
                    <th class="px-5 py-3 text-left text-xs font-semibold text-gray-500 uppercase">Cotizaciones</th>
                    <th class="px-5 py-3 text-left text-xs font-semibold text-gray-500 uppercase">Ventas</th>
                    <th class="px-5 py-3 text-left text-xs font-semibold text-gray-500 uppercase">Ingresos</th>
                    <th class="px-5 py-3 text-left text-xs font-semibold text-gray-500 uppercase">Conversión</th>
                    <th class="px-5 py-3 text-left text-xs font-semibold text-gray-500 uppercase">Variación</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-gray-100" id="tablaResumen"></tbody>
        </table>
    </div>
</div>

{% endblock %}

{% block javascripts %}
<script>
// ── Gráfica ventas por mes ─────────────────────────────────
new Chart(document.getElementById('chartVentas'), {
    type: 'bar',
    data: {
        labels: ['Ene','Feb','Mar','Abr','May','Jun','Jul','Ago','Sep','Oct','Nov','Dic'],
        datasets: [
            { label:'Unidades', data:[10,14,12,18,20,16,22,19,24,21,18,25], backgroundColor:'rgba(59,130,246,0.8)', borderRadius:5, yAxisID:'y' },
            { label:'Ingresos (k)', type:'line', data:[280,380,320,490,540,430,610,510,660,570,490,700], borderColor:'#10b981', backgroundColor:'rgba(16,185,129,0.1)', pointBackgroundColor:'#10b981', tension:0.4, fill:true, yAxisID:'y1' },
        ]
    },
    options: {
        responsive:true, interaction:{mode:'index',intersect:false},
        plugins:{legend:{display:false}},
        scales:{
            y:{ beginAtZero:true, grid:{color:'#f3f4f6'}, ticks:{color:'#9ca3af'} },
            y1:{ beginAtZero:true, position:'right', grid:{display:false}, ticks:{color:'#9ca3af'} }
        }
    }
});

// ── Gráfica marcas (doughnut) ─────────────────────────────
const marcasData = { labels:['Quantum Nexus Pluz','Quantum E-4','Quantum Ion','Quantum Ion Pro','Quantum Equte'], data:[38,22,18,12,8,2] };
const marcasColors = ['#3b82f6','#10b981','#f59e0b','#8b5cf6','#ef4444','#6b7280'];
new Chart(document.getElementById('chartMarcas'), {
    type:'doughnut',
    data:{ labels:marcasData.labels, datasets:[{ data:marcasData.data, backgroundColor:marcasColors, borderWidth:2, borderColor:'#fff' }] },
    options:{ responsive:true, plugins:{legend:{display:false}}, cutout:'70%' }
});
document.getElementById('marcasLegend').innerHTML = marcasData.labels.map((l,i) =>
    `<div class="flex items-center justify-between text-xs">
        <span class="flex items-center gap-2"><span class="w-3 h-3 rounded-full shrink-0" style="background:${marcasColors[i]}"></span>${l}</span>
        <span class="font-semibold text-gray-700">${marcasData.data[i]}%</span>
    </div>`).join('');

// ── Embudo de conversión ───────────────────────────────────
const stages = [
    { label:'Leads totales',  val:415, pct:100, color:'bg-blue-500'   },
    { label:'Contactados',    val:312, pct:75,  color:'bg-indigo-500'  },
    { label:'Con cotización', val:198, pct:48,  color:'bg-amber-500'   },
    { label:'En negociación', val:89,  pct:21,  color:'bg-orange-500'  },
    { label:'Ganados',        val:142, pct:34,  color:'bg-green-500'   },
];
document.getElementById('embudo-conv').innerHTML = stages.map(s => `
    <div>
        <div class="flex items-center justify-between text-xs mb-1">
            <span class="text-gray-600 font-medium">${s.label}</span>
            <span class="font-bold text-gray-900">${s.val} <span class="text-gray-400 font-normal">(${s.pct}%)</span></span>
        </div>
        <div class="w-full bg-gray-100 rounded-full h-2.5">
            <div class="${s.color} h-2.5 rounded-full transition-all" style="width:${s.pct}%"></div>
        </div>
    </div>`).join('');

// ── Ranking asesores ──────────────────────────────────────
const asesores = [
    { nombre:'Ana García',   ventas:58, ingresos:'$1.8M', conv:'41%', avatar:'AG', color:'from-amber-400 to-orange-500'  },
    { nombre:'Juan Pérez',   ventas:45, ingresos:'$1.4M', conv:'36%', avatar:'JP', color:'from-blue-400 to-blue-600'     },
    { nombre:'Luis Torres',  ventas:39, ingresos:'$1.2M', conv:'31%', avatar:'LT', color:'from-purple-400 to-purple-600' },
];
const medals = ['🥇','🥈','🥉'];
document.getElementById('rankingAsesores').innerHTML = asesores.map((a,i) => `
    <div class="flex items-center gap-3 p-3 rounded-xl ${i===0 ? 'bg-amber-50 border border-amber-100':'bg-gray-50'}">
        <span class="text-xl shrink-0">${medals[i]}</span>
        <div class="w-9 h-9 rounded-full bg-gradient-to-br ${a.color} flex items-center justify-center text-white text-sm font-bold shrink-0">${a.avatar}</div>
        <div class="flex-1 min-w-0">
            <p class="font-semibold text-gray-900 text-sm">${a.nombre}</p>
            <p class="text-xs text-gray-400">${a.ventas} ventas · Conv. ${a.conv}</p>
        </div>
        <p class="font-bold text-gray-900 text-sm shrink-0">${a.ingresos}</p>
    </div>`).join('');

// ── Tabla resumen mensual ─────────────────────────────────
const resumen = [
    { mes:'Enero 2024',    leads:42, cot:28, ventas:10, ingresos:'$280,000', conv:'23.8%', var:'+5%',  pos:true  },
    { mes:'Febrero 2024',  leads:55, cot:38, ventas:14, ingresos:'$380,000', conv:'25.5%', var:'+40%', pos:true  },
    { mes:'Marzo 2024',    leads:61, cot:40, ventas:12, ingresos:'$320,000', conv:'19.7%', var:'-14%', pos:false },
    { mes:'Abril 2024',    leads:72, cot:50, ventas:18, ingresos:'$490,000', conv:'25.0%', var:'+50%', pos:true  },
    { mes:'Mayo 2024',     leads:80, cot:55, ventas:20, ingresos:'$540,000', conv:'25.0%', var:'+10%', pos:true  },
    { mes:'Junio 2024',    leads:68, cot:45, ventas:16, ingresos:'$430,000', conv:'23.5%', var:'-20%', pos:false },
];
document.getElementById('tablaResumen').innerHTML = resumen.map(r => `
    <tr class="hover:bg-gray-50 transition-colors">
        <td class="px-5 py-3 text-sm font-medium text-gray-900">${r.mes}</td>
        <td class="px-5 py-3 text-sm text-gray-600">${r.leads}</td>
        <td class="px-5 py-3 text-sm text-gray-600">${r.cot}</td>
        <td class="px-5 py-3 text-sm font-semibold text-gray-900">${r.ventas}</td>
        <td class="px-5 py-3 text-sm font-semibold text-gray-900">${r.ingresos}</td>
        <td class="px-5 py-3 text-sm text-gray-600">${r.conv}</td>
        <td class="px-5 py-3">
            <span class="text-xs font-bold ${r.pos ? 'text-green-600':'text-red-500'}">
                <i class="fas fa-arrow-${r.pos?'up':'down'} mr-0.5"></i>${r.var}
            </span>
        </td>
    </tr>`).join('');

// ── Selector de período ─────────────────────────────────
document.querySelectorAll('.period-btn').forEach(btn => {
    btn.addEventListener('click', () => {
        document.querySelectorAll('.period-btn').forEach(b => b.classList.remove('bg-blue-600','text-white'));
        btn.classList.add('bg-blue-600','text-white');
    });
});
</script>
{% endblock %}
