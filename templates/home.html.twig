{% extends 'base.html.twig' %}

{% block title %}Dashboard - AutoSales Pro{% endblock %}
{% block page_title %}Dashboard{% endblock %}
{% block page_subtitle %}Panel principal de ventas{% endblock %}

{% block body %}
<!-- Métricas principales -->
<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-6">
    <!-- Ventas del mes -->
    <div class="bg-white rounded-lg shadow-sm p-6">
        <div class="flex items-center justify-between">
            <div>
                <p class="text-sm text-gray-600 font-medium">Ventas del Mes</p>
                <p class="text-3xl font-bold text-gray-900 mt-2">8</p>
                <p class="text-sm text-green-600 mt-1">
                    <i class="fas fa-arrow-up"></i> +15% vs mes anterior
                </p>
            </div>
            <div class="w-14 h-14 bg-blue-100 rounded-lg flex items-center justify-center">
                <i class="fas fa-handshake text-2xl text-blue-600"></i>
            </div>
        </div>
    </div>
    
    <!-- Ingresos -->
    <div class="bg-white rounded-lg shadow-sm p-6">
        <div class="flex items-center justify-between">
            <div>
                <p class="text-sm text-gray-600 font-medium">Ingresos</p>
                <p class="text-3xl font-bold text-gray-900 mt-2">$245K</p>
                <p class="text-sm text-green-600 mt-1">
                    <i class="fas fa-arrow-up"></i> +22% vs mes anterior
                </p>
            </div>
            <div class="w-14 h-14 bg-green-100 rounded-lg flex items-center justify-center">
                <i class="fas fa-dollar-sign text-2xl text-green-600"></i>
            </div>
        </div>
    </div>
    
    <!-- Clientes activos -->
    <div class="bg-white rounded-lg shadow-sm p-6">
        <div class="flex items-center justify-between">
            <div>
                <p class="text-sm text-gray-600 font-medium">Clientes Activos</p>
                <p class="text-3xl font-bold text-gray-900 mt-2">24</p>
                <p class="text-sm text-gray-500 mt-1">
                    12 en negociación
                </p>
            </div>
            <div class="w-14 h-14 bg-amber-100 rounded-lg flex items-center justify-center">
                <i class="fas fa-users text-2xl text-amber-600"></i>
            </div>
        </div>
    </div>
    
    <!-- Comisiones -->
    <div class="bg-white rounded-lg shadow-sm p-6">
        <div class="flex items-center justify-between">
            <div>
                <p class="text-sm text-gray-600 font-medium">Mis Comisiones</p>
                <p class="text-3xl font-bold text-gray-900 mt-2">$12.5K</p>
                <p class="text-sm text-green-600 mt-1">
                    <i class="fas fa-arrow-up"></i> +18% vs mes anterior
                </p>
            </div>
            <div class="w-14 h-14 bg-purple-100 rounded-lg flex items-center justify-center">
                <i class="fas fa-chart-line text-2xl text-purple-600"></i>
            </div>
        </div>
    </div>
</div>

<div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
    <!-- Embudo de ventas resumen -->
    <div class="lg:col-span-2 bg-white rounded-lg shadow-sm p-6">
        <div class="flex items-center justify-between mb-4">
            <h3 class="text-lg font-bold text-gray-900">Embudo de Ventas</h3>
            <a href="/?action=embudo" class="text-sm text-blue-600 hover:text-blue-700 font-medium">Ver todo</a>
        </div>
        
        <div class="space-y-4">
            <div class="flex items-center">
                <div class="flex-1">
                    <div class="flex items-center justify-between mb-1">
                        <span class="text-sm font-medium text-gray-700">Nuevo Lead</span>
                        <span class="text-sm text-gray-600">15 clientes</span>
                    </div>
                    <div class="w-full bg-gray-200 rounded-full h-2">
                        <div class="bg-blue-600 h-2 rounded-full" style="width: 100%"></div>
                    </div>
                </div>
            </div>
            
            <div class="flex items-center">
                <div class="flex-1">
                    <div class="flex items-center justify-between mb-1">
                        <span class="text-sm font-medium text-gray-700">Contactado</span>
                        <span class="text-sm text-gray-600">12 clientes</span>
                    </div>
                    <div class="w-full bg-gray-200 rounded-full h-2">
                        <div class="bg-indigo-600 h-2 rounded-full" style="width: 80%"></div>
                    </div>
                </div>
            </div>
            
            <div class="flex items-center">
                <div class="flex-1">
                    <div class="flex items-center justify-between mb-1">
                        <span class="text-sm font-medium text-gray-700">Test Drive</span>
                        <span class="text-sm text-gray-600">8 clientes</span>
                    </div>
                    <div class="w-full bg-gray-200 rounded-full h-2">
                        <div class="bg-purple-600 h-2 rounded-full" style="width: 53%"></div>
                    </div>
                </div>
            </div>
            
            <div class="flex items-center">
                <div class="flex-1">
                    <div class="flex items-center justify-between mb-1">
                        <span class="text-sm font-medium text-gray-700">Negociación</span>
                        <span class="text-sm text-gray-600">5 clientes</span>
                    </div>
                    <div class="w-full bg-gray-200 rounded-full h-2">
                        <div class="bg-amber-600 h-2 rounded-full" style="width: 33%"></div>
                    </div>
                </div>
            </div>
            
            <div class="flex items-center">
                <div class="flex-1">
                    <div class="flex items-center justify-between mb-1">
                        <span class="text-sm font-medium text-gray-700">Ganado</span>
                        <span class="text-sm text-gray-600">3 clientes</span>
                    </div>
                    <div class="w-full bg-gray-200 rounded-full h-2">
                        <div class="bg-green-600 h-2 rounded-full" style="width: 20%"></div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    
    <!-- Actividades recientes -->
    <div class="bg-white rounded-lg shadow-sm p-6">
        <h3 class="text-lg font-bold text-gray-900 mb-4">Actividades Recientes</h3>
        
        <div class="space-y-4">
            <div class="flex items-start space-x-3">
                <div class="w-8 h-8 bg-green-100 rounded-full flex items-center justify-center flex-shrink-0">
                    <i class="fas fa-check text-green-600 text-sm"></i>
                </div>
                <div class="flex-1 min-w-0">
                    <p class="text-sm font-medium text-gray-900">Venta cerrada</p>
                    <p class="text-xs text-gray-600">Carlos Pérez - Quantum</p>
                    <p class="text-xs text-gray-400 mt-1">Hace 2 horas</p>
                </div>
            </div>
            
            <div class="flex items-start space-x-3">
                <div class="w-8 h-8 bg-blue-100 rounded-full flex items-center justify-center flex-shrink-0">
                    <i class="fas fa-comments text-blue-600 text-sm"></i>
                </div>
                <div class="flex-1 min-w-0">
                    <p class="text-sm font-medium text-gray-900">Mensaje de WhatsApp</p>
                    <p class="text-xs text-gray-600">María González pregunta por financiamiento</p>
                    <p class="text-xs text-gray-400 mt-1">Hace 3 horas</p>
                </div>
            </div>
            
            <div class="flex items-start space-x-3">
                <div class="w-8 h-8 bg-purple-100 rounded-full flex items-center justify-center flex-shrink-0">
                    <i class="fas fa-road text-purple-600 text-sm"></i>
                </div>
                <div class="flex-1 min-w-0">
                    <p class="text-sm font-medium text-gray-900">Test drive agendado</p>
                    <p class="text-xs text-gray-600">Luis Fernández - Quantum</p>
                    <p class="text-xs text-gray-400 mt-1">Hace 5 horas</p>
                </div>
            </div>
            
            <div class="flex items-start space-x-3">
                <div class="w-8 h-8 bg-amber-100 rounded-full flex items-center justify-center flex-shrink-0">
                    <i class="fas fa-file-invoice-dollar text-amber-600 text-sm"></i>
                </div>
                <div class="flex-1 min-w-0">
                    <p class="text-sm font-medium text-gray-900">Cotización enviada</p>
                    <p class="text-xs text-gray-600">Ana Martínez - Quantum</p>
                    <p class="text-xs text-gray-400 mt-1">Hace 1 día</p>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Próximas tareas -->
<div class="mt-6 bg-white rounded-lg shadow-sm p-6">
    <h3 class="text-lg font-bold text-gray-900 mb-4">Próximas Tareas</h3>
    
    <div class="space-y-3">
        <div class="flex items-center justify-between p-4 bg-yellow-50 border border-yellow-200 rounded-lg">
            <div class="flex items-center space-x-3">
                <input type="checkbox" class="w-5 h-5 text-blue-600 rounded">
                <div>
                    <p class="text-sm font-medium text-gray-900">Llamar a Roberto Silva</p>
                    <p class="text-xs text-gray-600">Seguimiento de cotización Mazda CX-5</p>
                </div>
            </div>
            <span class="text-xs font-medium text-amber-600">Hoy 14:00</span>
        </div>
        
        <div class="flex items-center justify-between p-4 bg-gray-50 border border-gray-200 rounded-lg">
            <div class="flex items-center space-x-3">
                <input type="checkbox" class="w-5 h-5 text-blue-600 rounded">
                <div>
                    <p class="text-sm font-medium text-gray-900">Preparar documentos de venta</p>
                    <p class="text-xs text-gray-600">Carlos Pérez - Quantum</p>
                </div>
            </div>
            <span class="text-xs font-medium text-gray-600">Hoy 16:30</span>
        </div>
        
        <div class="flex items-center justify-between p-4 bg-gray-50 border border-gray-200 rounded-lg">
            <div class="flex items-center space-x-3">
                <input type="checkbox" class="w-5 h-5 text-blue-600 rounded">
                <div>
                    <p class="text-sm font-medium text-gray-900">Test drive con Luis Fernández</p>
                    <p class="text-xs text-gray-600">Quantum 2024</p>
                </div>
            </div>
            <span class="text-xs font-medium text-gray-600">Mañana 10:00</span>
        </div>
    </div>
</div>
{% endblock %}
