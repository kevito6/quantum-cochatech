{% extends 'base.html.twig' %}

{% block title %}Chat - AutoSales Pro{% endblock %}
{% block page_title %}Chat Unificado{% endblock %}
{% block page_subtitle %}Mensajería integrada{% endblock %}

{% block stylesheets %}
<style>
    .chat-list { max-height: calc(100vh - 280px); }
    .chat-messages { max-height: calc(100vh - 340px); }
</style>
{% endblock %}

{% block body %}
<div class="grid grid-cols-1 lg:grid-cols-3 gap-6 h-[calc(100vh-200px)]">
    
    <!-- Lista de conversaciones -->
    <div class="bg-white rounded-lg shadow-sm overflow-hidden flex flex-col">
        <div class="p-4 border-b border-gray-200">
            <div class="relative">
                <input type="text" 
                       placeholder="Buscar conversación..." 
                       class="w-full pl-10 pr-4 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-blue-500">
                <i class="fas fa-search absolute left-3 top-1/2 -translate-y-1/2 text-gray-400"></i>
            </div>
        </div>
        
        <div class="flex items-center space-x-2 px-4 py-3 border-b border-gray-200 bg-gray-50">
            <button class="px-3 py-1.5 bg-blue-600 text-white text-xs font-medium rounded-lg">
                Todos (24)
            </button>
            <button class="px-3 py-1.5 bg-white text-gray-700 text-xs font-medium rounded-lg border border-gray-300 hover:bg-gray-50">
                WhatsApp (15)
            </button>
            <button class="px-3 py-1.5 bg-white text-gray-700 text-xs font-medium rounded-lg border border-gray-300 hover:bg-gray-50">
                Email (9)
            </button>
        </div>
        
        <div class="chat-list flex-1 overflow-y-auto">
            <!-- Conversación activa -->
            <div class="p-4 border-b border-gray-200 bg-blue-50 hover:bg-blue-100 cursor-pointer transition-colors">
                <div class="flex items-start space-x-3">
                    <div class="relative flex-shrink-0">
                        <div class="w-12 h-12 rounded-full bg-gradient-to-br from-purple-400 to-purple-600 flex items-center justify-center text-white font-bold">
                            MG
                        </div>
                        <span class="absolute bottom-0 right-0 w-3 h-3 bg-green-500 border-2 border-white rounded-full"></span>
                    </div>
                    <div class="flex-1 min-w-0">
                        <div class="flex items-start justify-between mb-1">
                            <h4 class="text-sm font-semibold text-gray-900 truncate">María González</h4>
                            <span class="text-xs text-gray-500">10:45</span>
                        </div>
                        <div class="flex items-center space-x-2 mb-1">
                            <i class="fab fa-whatsapp text-green-500 text-xs"></i>
                            <p class="text-xs text-gray-600 truncate">¿Tienen opciones de financiamiento?</p>
                        </div>
                        <span class="inline-block px-2 py-0.5 bg-green-500 text-white text-xs rounded-full">2 nuevos</span>
                    </div>
                </div>
            </div>
            
            <!-- Otras conversaciones -->
            <div class="p-4 border-b border-gray-200 hover:bg-gray-50 cursor-pointer transition-colors">
                <div class="flex items-start space-x-3">
                    <div class="relative flex-shrink-0">
                        <div class="w-12 h-12 rounded-full bg-gradient-to-br from-blue-400 to-blue-600 flex items-center justify-center text-white font-bold">
                            CP
                        </div>
                        <span class="absolute bottom-0 right-0 w-3 h-3 bg-gray-400 border-2 border-white rounded-full"></span>
                    </div>
                    <div class="flex-1 min-w-0">
                        <div class="flex items-start justify-between mb-1">
                            <h4 class="text-sm font-semibold text-gray-900 truncate">Carlos Pérez</h4>
                            <span class="text-xs text-gray-500">Ayer</span>
                        </div>
                        <div class="flex items-center space-x-2">
                            <i class="fas fa-envelope text-blue-500 text-xs"></i>
                            <p class="text-xs text-gray-600 truncate">Gracias por la atención!</p>
                        </div>
                    </div>
                </div>
            </div>
            
            <div class="p-4 border-b border-gray-200 hover:bg-gray-50 cursor-pointer transition-colors">
                <div class="flex items-start space-x-3">
                    <div class="relative flex-shrink-0">
                        <div class="w-12 h-12 rounded-full bg-gradient-to-br from-amber-400 to-amber-600 flex items-center justify-center text-white font-bold">
                            LF
                        </div>
                        <span class="absolute bottom-0 right-0 w-3 h-3 bg-green-500 border-2 border-white rounded-full"></span>
                    </div>
                    <div class="flex-1 min-w-0">
                        <div class="flex items-start justify-between mb-1">
                            <h4 class="text-sm font-semibold text-gray-900 truncate">Luis Fernández</h4>
                            <span class="text-xs text-gray-500">2 días</span>
                        </div>
                        <div class="flex items-center space-x-2 mb-1">
                            <i class="fab fa-whatsapp text-green-500 text-xs"></i>
                            <p class="text-xs text-gray-600 truncate">Perfecto, nos vemos mañana</p>
                        </div>
                        <span class="inline-block px-2 py-0.5 bg-blue-100 text-blue-700 text-xs rounded-full">1 nuevo</span>
                    </div>
                </div>
            </div>
            
            <div class="p-4 border-b border-gray-200 hover:bg-gray-50 cursor-pointer transition-colors">
                <div class="flex items-start space-x-3">
                    <div class="relative flex-shrink-0">
                        <div class="w-12 h-12 rounded-full bg-gradient-to-br from-pink-400 to-pink-600 flex items-center justify-center text-white font-bold">
                            AM
                        </div>
                        <span class="absolute bottom-0 right-0 w-3 h-3 bg-gray-400 border-2 border-white rounded-full"></span>
                    </div>
                    <div class="flex-1 min-w-0">
                        <div class="flex items-start justify-between mb-1">
                            <h4 class="text-sm font-semibold text-gray-900 truncate">Ana Martínez</h4>
                            <span class="text-xs text-gray-500">3 días</span>
                        </div>
                        <div class="flex items-center space-x-2">
                            <i class="fas fa-envelope text-blue-500 text-xs"></i>
                            <p class="text-xs text-gray-600 truncate">Me interesa la cotización</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    
    <!-- Área de conversación -->
    <div class="lg:col-span-2 bg-white rounded-lg shadow-sm overflow-hidden flex flex-col">
        <!-- Header de la conversación -->
        <div class="p-4 border-b border-gray-200 bg-gradient-to-r from-blue-50 to-indigo-50">
            <div class="flex items-center justify-between">
                <div class="flex items-center space-x-3">
                    <div class="w-10 h-10 rounded-full bg-gradient-to-br from-purple-400 to-purple-600 flex items-center justify-center text-white font-bold">
                        MG
                    </div>
                    <div>
                        <h3 class="text-sm font-bold text-gray-900">María González</h3>
                        <div class="flex items-center space-x-2">
                            <i class="fab fa-whatsapp text-green-500 text-xs"></i>
                            <span class="text-xs text-green-600">En línea</span>
                        </div>
                    </div>
                </div>
                <div class="flex items-center space-x-2">
                    <button class="p-2 text-gray-600 hover:bg-white rounded-lg transition-colors" title="Información del cliente">
                        <i class="fas fa-info-circle"></i>
                    </button>
                    <button class="p-2 text-gray-600 hover:bg-white rounded-lg transition-colors" title="Más opciones">
                        <i class="fas fa-ellipsis-v"></i>
                    </button>
                </div>
            </div>
        </div>
        
        <!-- Mensajes -->
        <div class="chat-messages flex-1 overflow-y-auto p-4 bg-gray-50">
            <div class="space-y-4">
                <!-- Mensaje del cliente -->
                <div class="flex items-start space-x-2">
                    <div class="w-8 h-8 rounded-full bg-gradient-to-br from-purple-400 to-purple-600 flex items-center justify-center text-white text-xs font-bold flex-shrink-0">
                        MG
                    </div>
                    <div class="flex-1">
                        <div class="bg-white rounded-lg rounded-tl-none p-3 shadow-sm max-w-md">
                            <p class="text-sm text-gray-800">Hola, buenos días. Estoy interesada en el Quantum que vi en su página.</p>
                        </div>
                        <span class="text-xs text-gray-500 mt-1 block">10:30</span>
                    </div>
                </div>
                
                <!-- Mensaje del asesor -->
                <div class="flex items-start space-x-2 justify-end">
                    <div class="flex-1 flex flex-col items-end">
                        <div class="bg-blue-600 text-white rounded-lg rounded-tr-none p-3 shadow-sm max-w-md">
                            <p class="text-sm">¡Hola María! Excelente elección. Tenemos el Quantum 2024 disponible en varios colores. ¿Te gustaría agendar un test drive?</p>
                        </div>
                        <span class="text-xs text-gray-500 mt-1 block">10:32</span>
                    </div>
                    <div class="w-8 h-8 rounded-full bg-gradient-to-br from-amber-400 to-orange-500 flex items-center justify-center text-white text-xs font-bold flex-shrink-0">
                        AS
                    </div>
                </div>
                
                <!-- Mensaje del cliente -->
                <div class="flex items-start space-x-2">
                    <div class="w-8 h-8 rounded-full bg-gradient-to-br from-purple-400 to-purple-600 flex items-center justify-center text-white text-xs font-bold flex-shrink-0">
                        MG
                    </div>
                    <div class="flex-1">
                        <div class="bg-white rounded-lg rounded-tl-none p-3 shadow-sm max-w-md">
                            <p class="text-sm text-gray-800">Sí, me encantaría. ¿Cuál es el precio y tienen opciones de financiamiento?</p>
                        </div>
                        <span class="text-xs text-gray-500 mt-1 block">10:45</span>
                    </div>
                </div>
                
                <!-- Indicador escribiendo -->
                <div class="flex items-start space-x-2">
                    <div class="w-8 h-8 rounded-full bg-gradient-to-br from-amber-400 to-orange-500 flex items-center justify-center text-white text-xs font-bold flex-shrink-0">
                        AS
                    </div>
                    <div class="bg-white rounded-lg rounded-tl-none p-3 shadow-sm">
                        <div class="flex space-x-1">
                            <div class="w-2 h-2 bg-gray-400 rounded-full animate-bounce"></div>
                            <div class="w-2 h-2 bg-gray-400 rounded-full animate-bounce" style="animation-delay: 0.2s"></div>
                            <div class="w-2 h-2 bg-gray-400 rounded-full animate-bounce" style="animation-delay: 0.4s"></div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        
        <!-- Input de mensaje -->
        <div class="p-4 border-t border-gray-200 bg-white">
            <div class="flex items-end space-x-2">
                <button class="p-2 text-gray-600 hover:bg-gray-100 rounded-lg transition-colors">
                    <i class="fas fa-paperclip text-xl"></i>
                </button>
                
                <div class="flex-1">
                    <textarea 
                        placeholder="Escribe tu mensaje..." 
                        rows="2"
                        class="w-full px-4 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 resize-none"></textarea>
                </div>
                
                <div class="flex flex-col space-y-2">
                    <button class="p-2 text-gray-600 hover:bg-gray-100 rounded-lg transition-colors" title="Plantillas">
                        <i class="fas fa-file-alt text-xl"></i>
                    </button>
                    <button class="p-2 bg-blue-600 text-white hover:bg-blue-700 rounded-lg transition-colors" title="Enviar">
                        <i class="fas fa-paper-plane text-xl"></i>
                    </button>
                </div>
            </div>
            
            <!-- Acciones rápidas -->
            <div class="flex items-center space-x-2 mt-3">
                <button class="px-3 py-1.5 bg-gray-100 text-gray-700 text-xs rounded-lg hover:bg-gray-200 transition-colors">
                    <i class="fas fa-file-invoice-dollar mr-1"></i>
                    Enviar cotización
                </button>
                <button class="px-3 py-1.5 bg-gray-100 text-gray-700 text-xs rounded-lg hover:bg-gray-200 transition-colors">
                    <i class="fas fa-calendar mr-1"></i>
                    Agendar cita
                </button>
                <button class="px-3 py-1.5 bg-gray-100 text-gray-700 text-xs rounded-lg hover:bg-gray-200 transition-colors">
                    <i class="fas fa-car mr-1"></i>
                    Enviar ficha técnica
                </button>
            </div>
        </div>
    </div>
</div>
{% endblock %}
