<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}Quantum Motors{% endblock %}</title>
    
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        primary: '#1e40af',
                        secondary: '#64748b',
                        accent: '#f59e0b',
                        success: '#10b981',
                        danger: '#ef4444'
                    }
                }
            }
        }
    </script>
    
    <style>
        .sidebar-transition { transition: transform 0.3s ease-in-out; }
        .nav-item:hover { background: linear-gradient(90deg, rgba(30, 64, 175, 0.1) 0%, transparent 100%); }
        @keyframes pulse-badge {
            0%, 100% { opacity: 1; }
            50% { opacity: 0.5; }
        }
        .pulse-badge { animation: pulse-badge 2s cubic-bezier(0.4, 0, 0.6, 1) infinite; }
    </style>
    
    {% block stylesheets %}{% endblock %}
</head>
<body class="bg-gray-50 font-sans antialiased">
    
    <!-- Overlay para móviles -->
    <div id="sidebar-overlay" class="fixed inset-0 bg-black bg-opacity-50 z-40 lg:hidden hidden"></div>
    
    <!-- Sidebar -->
    <aside id="sidebar" class="fixed top-0 left-0 z-50 w-64 h-screen bg-gradient-to-b from-slate-900 to-slate-800 text-white sidebar-transition -translate-x-full lg:translate-x-0">
        <div class="flex flex-col h-full">
            
            <!-- Logo -->
            <div class="flex items-center justify-between px-6 py-5 border-b border-slate-700">
                <div class="flex items-center space-x-3">
                    <div>
                        <h1 class="text-lg font-bold">Quantum</h1>
                        <p class="text-xs text-slate-400">Sistema de Ventas</p>
                    </div>
                </div>
                <button id="sidebar-close" class="lg:hidden text-slate-400 hover:text-white">
                    <i class="fas fa-times text-xl"></i>
                </button>
            </div>
            
            <!-- Perfil del asesor -->
            <div class="px-6 py-4 bg-slate-800/50">
                <div class="flex items-center space-x-3">
                    <div class="flex-1 min-w-0">
                        <p class="font-semibold text-sm truncate">{{ user_name|default('Asesor de Ventas') }}</p>
                        <p class="text-xs text-slate-400 truncate">{{ user_email|default('asesor@quantum.com') }}</p>
                    </div>
                </div>
            </div>
            
            <!-- Navegación -->
            <nav class="flex-1 px-3 py-4 overflow-y-auto">
                <ul class="space-y-1">
                    <li>
                        <a href="/?action=dashboard" class="nav-item flex items-center px-3 py-2.5 rounded-lg text-sm font-medium hover:bg-slate-700/50 transition-colors" data-page="dashboard">
                            <i class="fas fa-home w-5"></i>
                            <span class="ml-3">Dashboard</span>
                        </a>
                    </li>
                    
                    <li>
                        <a href="/?action=embudo" class="nav-item flex items-center px-3 py-2.5 rounded-lg text-sm font-medium hover:bg-slate-700/50 transition-colors" data-page="embudo">
                            <i class="fas fa-filter w-5"></i>
                            <span class="ml-3">Embudo de Ventas</span>
                            <span class="ml-auto bg-blue-500 text-xs px-2 py-0.5 rounded-full">12</span>
                        </a>
                    </li>
                    
                    <li>
                        <a href="/?action=chat" class="nav-item flex items-center px-3 py-2.5 rounded-lg text-sm font-medium hover:bg-slate-700/50 transition-colors" data-page="chat">
                            <i class="fas fa-comments w-5"></i>
                            <span class="ml-3">Chat</span>
                            <span class="ml-auto bg-green-500 text-xs px-2 py-0.5 rounded-full pulse-badge">5</span>
                        </a>
                    </li>
                    
                    <li>
                        <a href="/?action=clientes" class="nav-item flex items-center px-3 py-2.5 rounded-lg text-sm font-medium hover:bg-slate-700/50 transition-colors" data-page="clientes">
                            <i class="fas fa-users w-5"></i>
                            <span class="ml-3">Usuarios</span>
                        </a>
                    </li>
                    
                    <li>
                        <a href="/?action=inventario" class="nav-item flex items-center px-3 py-2.5 rounded-lg text-sm font-medium hover:bg-slate-700/50 transition-colors" data-page="inventario">
                            <i class="fas fa-car w-5"></i>
                            <span class="ml-3">Inventario</span>
                        </a>
                    </li>
                    
                    <li>
                        <a href="/?action=cotizaciones" class="nav-item flex items-center px-3 py-2.5 rounded-lg text-sm font-medium hover:bg-slate-700/50 transition-colors" data-page="cotizaciones">
                            <i class="fas fa-file-invoice-dollar w-5"></i>
                            <span class="ml-3">Cotizaciones</span>
                            <span class="ml-auto bg-amber-500 text-xs px-2 py-0.5 rounded-full">3</span>
                        </a>
                    </li>
                    
                    <li>
                        <a href="/?action=ventas" class="nav-item flex items-center px-3 py-2.5 rounded-lg text-sm font-medium hover:bg-slate-700/50 transition-colors" data-page="ventas">
                            <i class="fas fa-handshake w-5"></i>
                            <span class="ml-3">Mis Ventas</span>
                        </a>
                    </li>
                    
                    <li class="pt-4 pb-2">
                        <p class="px-3 text-xs font-semibold text-slate-500 uppercase tracking-wider">Reportes</p>
                    </li>
                    
                    <li>
                        <a href="/?action=comisiones" class="nav-item flex items-center px-3 py-2.5 rounded-lg text-sm font-medium hover:bg-slate-700/50 transition-colors" data-page="comisiones">
                            <i class="fas fa-chart-line w-5"></i>
                            <span class="ml-3">Mis Comisiones</span>
                        </a>
                    </li>
                    
                    <li>
                        <a href="/?action=estadisticas" class="nav-item flex items-center px-3 py-2.5 rounded-lg text-sm font-medium hover:bg-slate-700/50 transition-colors" data-page="estadisticas">
                            <i class="fas fa-chart-bar w-5"></i>
                            <span class="ml-3">Estadísticas</span>
                        </a>
                    </li>
                </ul>
            </nav>
            
            <!-- Footer del sidebar -->
            <div class="px-6 py-4 border-t border-slate-700">
                <a href="/?action=configuracion" class="flex items-center text-sm text-slate-400 hover:text-white transition-colors">
                    <i class="fas fa-cog w-5"></i>
                    <span class="ml-3">Configuración</span>
                </a>
            </div>
        </div>
    </aside>
    
    <!-- Contenido principal -->
    <div class="lg:ml-64 min-h-screen flex flex-col">
        
        <!-- Navbar -->
        <header class="bg-white shadow-sm sticky top-0 z-30">
            <div class="flex items-center justify-between px-4 py-3 lg:px-6">
                
                <!-- Botón menú móvil y título -->
                <div class="flex items-center space-x-4">
                    <button id="sidebar-toggle" class="lg:hidden text-gray-600 hover:text-gray-900 focus:outline-none">
                        <i class="fas fa-bars text-xl"></i>
                    </button>
                    <div>
                        <h2 class="text-xl font-bold text-gray-800">{% block page_title %}Dashboard{% endblock %}</h2>
                        <p class="text-xs text-gray-500 hidden sm:block">{% block page_subtitle %}Panel principal de ventas{% endblock %}</p>
                    </div>
                </div>
                
                <!-- Acciones del navbar -->
                <div class="flex items-center space-x-3">
                    
                    <!-- Búsqueda rápida -->
                    <div class="hidden md:block relative">
                        <input type="text" 
                               placeholder="Buscar cliente, vehículo..." 
                               class="w-64 pl-10 pr-4 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent">
                        <i class="fas fa-search absolute left-3 top-1/2 -translate-y-1/2 text-gray-400"></i>
                    </div>
                    
                    <!-- Notificaciones -->
                    <div class="relative">
                        <button class="relative p-2 text-gray-600 hover:text-gray-900 hover:bg-gray-100 rounded-lg transition-colors">
                            <i class="fas fa-bell text-xl"></i>
                            <span class="absolute top-1 right-1 w-2 h-2 bg-red-500 rounded-full"></span>
                        </button>
                    </div>
                    
                    <!-- Botón acción rápida -->
                    <a href="/?action=cotizaciones&new=true" class="hidden sm:flex items-center px-4 py-2 bg-gradient-to-r from-blue-600 to-blue-700 text-white text-sm font-medium rounded-lg hover:from-blue-700 hover:to-blue-800 transition-all shadow-sm">
                        <i class="fas fa-plus mr-2"></i>
                        Nueva Cotización
                    </a>
                    
                    <!-- Menú usuario -->
                    <div class="relative">
                        <button class="flex items-center space-x-2 p-2 hover:bg-gray-100 rounded-lg transition-colors">
                            <div class="w-8 h-8 rounded-full bg-gradient-to-br from-amber-400 to-orange-500 flex items-center justify-center text-white text-sm font-bold">
                                {{ user_initials|default('AS') }}
                            </div>
                            <i class="fas fa-chevron-down text-gray-400 text-xs hidden lg:block"></i>
                        </button>
                    </div>
                </div>
            </div>
        </header>
        
        <!-- Área de contenido -->
        <main class="flex-1 p-4 lg:p-6">
            {% block body %}
            <!-- El contenido de cada página va aquí -->
            {% endblock %}
        </main>
        
        <!-- Footer -->
        <footer class="bg-white border-t border-gray-200 px-6 py-4">
            <div class="flex flex-col sm:flex-row justify-between items-center text-sm text-gray-600">
                <p>&copy; 2026 Quantum Motors. Todos los derechos reservados.</p>
                <p class="mt-2 sm:mt-0">Versión 2.0.1</p>
            </div>
        </footer>
    </div>
    
    <!-- Scripts -->
    <script>
        // Toggle sidebar en móviles
        const sidebarToggle = document.getElementById('sidebar-toggle');
        const sidebarClose = document.getElementById('sidebar-close');
        const sidebar = document.getElementById('sidebar');
        const overlay = document.getElementById('sidebar-overlay');
        
        function openSidebar() {
            sidebar.classList.remove('-translate-x-full');
            overlay.classList.remove('hidden');
        }
        
        function closeSidebar() {
            sidebar.classList.add('-translate-x-full');
            overlay.classList.add('hidden');
        }
        
        sidebarToggle.addEventListener('click', openSidebar);
        sidebarClose.addEventListener('click', closeSidebar);
        overlay.addEventListener('click', closeSidebar);
        
        // Cerrar sidebar al cambiar a desktop
        window.addEventListener('resize', () => {
            if (window.innerWidth >= 1024) {
                overlay.classList.add('hidden');
            }
        });
        
        // Marcar item activo del menú
        const urlParams = new URLSearchParams(window.location.search);
        const currentAction = urlParams.get('action') || 'dashboard';
        
        document.querySelectorAll('.nav-item').forEach(link => {
            const linkAction = link.getAttribute('data-page');
            if (linkAction === currentAction) {
                link.classList.add('bg-blue-600', 'text-white');
            }
        });
    </script>
    
    {% block javascripts %}{% endblock %}
</body>
</html>
